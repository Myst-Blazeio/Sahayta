FLASK_ENV=development
SECRET_KEY=your_256bit_secret_key_here
MONGO_URI=mongodb://localhost:27017/fir_automation
JWT_SECRET_KEY=your_256bit_jwt_secret_here

# Render deployment — set to your live URL to enable keep-alive pinging
RENDER_URL=https://your-app-name.onrender.com

# Gunicorn worker count (default 2)
WEB_CONCURRENCY=2
